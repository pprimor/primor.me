{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "types": [
      "vite/client",
      "@cloudflare/workers-types",
      "@cloudflare/vitest-pool-workers"
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "src/**/*",
    "functions/**/*",
    "App.tsx",
    "main.tsx",
    "vite.config.ts",
    "vitest.config.ts",
    "vitest-env.d.ts"
  ],
  "exclude": ["node_modules", ".next", "out"]
}
